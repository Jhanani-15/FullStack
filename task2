<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>TaskFlow</title>
<style>
  :root{--bg:#0f1117;--surface:#1a1d27;--card:#22263a;--accent:#6c63ff;--accent2:#ff6584;--text:#e2e8f0;--muted:#64748b;--green:#22c55e;--yellow:#eab308;--red:#ef4444;--radius:12px;--font:'Inter',system-ui,sans-serif}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh}
  /* AUTH */
  #auth{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:1rem}
  .auth-box{background:var(--surface);border:1px solid #2a2f45;border-radius:var(--radius);padding:2.5rem;width:100%;max-width:420px}
  .logo{font-size:1.8rem;font-weight:800;color:var(--accent);letter-spacing:-1px;margin-bottom:.25rem}
  .tagline{color:var(--muted);font-size:.85rem;margin-bottom:2rem}
  .tabs{display:flex;gap:.5rem;margin-bottom:1.5rem}
  .tab{flex:1;padding:.6rem;background:var(--card);border:none;border-radius:8px;color:var(--muted);cursor:pointer;font-size:.9rem;transition:.2s}
  .tab.active{background:var(--accent);color:#fff}
  .field{margin-bottom:1rem}
  .field label{display:block;font-size:.8rem;color:var(--muted);margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.05em}
  input[type=text],input[type=email],input[type=password],input[type=date],select,textarea{width:100%;background:var(--card);border:1px solid #2a2f45;border-radius:8px;color:var(--text);font-size:.9rem;padding:.65rem .9rem;outline:none;transition:.2s;font-family:var(--font)}
  input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(108,99,255,.15)}
  textarea{resize:vertical;min-height:80px}
  .btn{width:100%;padding:.75rem;background:var(--accent);color:#fff;border:none;border-radius:8px;font-size:.95rem;font-weight:600;cursor:pointer;transition:.2s;letter-spacing:.02em}
  .btn:hover{opacity:.9;transform:translateY(-1px)}
  .btn-sm{width:auto;padding:.4rem .85rem;font-size:.8rem;border-radius:6px}
  .btn-ghost{background:transparent;border:1px solid #2a2f45;color:var(--muted)}
  .btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
  .btn-danger{background:var(--red)}
  .err{color:var(--red);font-size:.82rem;margin-top:.75rem;text-align:center}
  /* APP */
  #app{display:none;flex-direction:column;min-height:100vh}
  header{background:var(--surface);border-bottom:1px solid #1e2236;padding:.85rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10}
  .header-left{display:flex;align-items:center;gap:.75rem}
  .logo-sm{font-size:1.3rem;font-weight:800;color:var(--accent)}
  .user-chip{background:var(--card);border:1px solid #2a2f45;border-radius:20px;padding:.35rem .85rem;font-size:.82rem;color:var(--muted)}
  .header-right{display:flex;align-items:center;gap:.75rem}
  main{max-width:1100px;margin:0 auto;padding:2rem 1.25rem;width:100%}
  .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1rem;margin-bottom:2rem}
  .stat{background:var(--surface);border:1px solid #2a2f45;border-radius:var(--radius);padding:1.25rem;text-align:center}
  .stat-num{font-size:2rem;font-weight:800;color:var(--accent)}
  .stat-label{font-size:.78rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-top:.2rem}
  .panel{background:var(--surface);border:1px solid #2a2f45;border-radius:var(--radius);padding:1.5rem;margin-bottom:1.5rem}
  .panel-title{font-size:1rem;font-weight:700;margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
  .filters{display:flex;flex-wrap:wrap;gap:.6rem;margin-bottom:1.25rem}
  .filter-btn{padding:.4rem .9rem;border-radius:20px;border:1px solid #2a2f45;background:none;color:var(--muted);font-size:.8rem;cursor:pointer;transition:.2s}
  .filter-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
  .task-list{display:flex;flex-direction:column;gap:.75rem}
  .task{background:var(--card);border:1px solid #2a2f45;border-radius:10px;padding:1rem 1.2rem;display:flex;align-items:flex-start;gap:.9rem;transition:.2s;animation:fadeIn .3s ease}
  .task:hover{border-color:#3a3f5c;transform:translateY(-1px)}
  @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
  .task.done{opacity:.55}
  .task.done .task-title{text-decoration:line-through;color:var(--muted)}
  .check{width:20px;height:20px;border-radius:50%;border:2px solid #3a3f5c;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:.2s;margin-top:2px}
  .check.done{background:var(--green);border-color:var(--green)}
  .check svg{display:none}
  .check.done svg{display:block}
  .task-body{flex:1;min-width:0}
  .task-title{font-size:.95rem;font-weight:600;margin-bottom:.3rem}
  .task-desc{font-size:.82rem;color:var(--muted);margin-bottom:.5rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .task-meta{display:flex;align-items:center;flex-wrap:wrap;gap:.5rem}
  .badge{padding:.2rem .6rem;border-radius:20px;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em}
  .p-high{background:rgba(239,68,68,.15);color:var(--red)}
  .p-medium{background:rgba(234,179,8,.15);color:var(--yellow)}
  .p-low{background:rgba(34,197,94,.15);color:var(--green)}
  .tag{background:#1e2236;color:var(--muted);padding:.2rem .55rem;border-radius:6px;font-size:.72rem}
  .due{font-size:.75rem;color:var(--muted)}
  .due.overdue{color:var(--red)}
  .task-actions{display:flex;gap:.4rem;flex-shrink:0}
  .icon-btn{background:none;border:none;color:var(--muted);cursor:pointer;padding:.3rem;border-radius:6px;transition:.2s;display:flex;align-items:center}
  .icon-btn:hover{background:var(--surface);color:var(--text)}
  .empty{text-align:center;padding:3rem 1rem;color:var(--muted)}
  .empty svg{width:48px;height:48px;opacity:.3;margin-bottom:1rem}
  /* MODAL */
  .overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:50;align-items:center;justify-content:center;padding:1rem}
  .overlay.open{display:flex}
  .modal{background:var(--surface);border:1px solid #2a2f45;border-radius:var(--radius);padding:2rem;width:100%;max-width:480px;animation:fadeIn .2s ease}
  .modal-title{font-size:1.1rem;font-weight:700;margin-bottom:1.5rem}
  .modal-actions{display:flex;gap:.75rem;margin-top:1.5rem}
  @media(max-width:600px){.form-row{grid-template-columns:1fr}.stats{grid-template-columns:repeat(2,1fr)}.modal-actions{flex-direction:column}}
</style>
</head>
<body>

<!-- AUTH SCREEN -->
<div id="auth">
  <div class="auth-box">
    <div class="logo">TaskFlow</div>
    <div class="tagline">Manage your work, simply.</div>
    <div class="tabs">
      <button class="tab active" onclick="switchTab('login')">Sign In</button>
      <button class="tab" onclick="switchTab('register')">Register</button>
    </div>
    <div id="login-form">
      <div class="field"><label>Email</label><input type="email" id="l-email" placeholder="you@example.com"></div>
      <div class="field"><label>Password</label><input type="password" id="l-pass" placeholder="••••••••"></div>
      <button class="btn" onclick="login()">Sign In</button>
      <div class="err" id="auth-err"></div>
      <p style="text-align:center;font-size:.78rem;color:var(--muted);margin-top:1rem">Demo: <b>demo@test.com</b> / <b>password</b></p>
    </div>
    <div id="register-form" style="display:none">
      <div class="field"><label>Name</label><input type="text" id="r-name" placeholder="Your Name"></div>
      <div class="field"><label>Email</label><input type="email" id="r-email" placeholder="you@example.com"></div>
      <div class="field"><label>Password</label><input type="password" id="r-pass" placeholder="••••••••"></div>
      <button class="btn" onclick="register()">Create Account</button>
      <div class="err" id="reg-err"></div>
    </div>
  </div>
</div>

<!-- MAIN APP -->
<div id="app">
  <header>
    <div class="header-left">
      <div class="logo-sm">TaskFlow</div>
      <span class="user-chip" id="user-name">User</span>
    </div>
    <div class="header-right">
      <button class="btn btn-sm" onclick="openModal()">+ Add Task</button>
      <button class="btn btn-sm btn-ghost" onclick="logout()">Sign Out</button>
    </div>
  </header>
  <main>
    <div class="stats">
      <div class="stat"><div class="stat-num" id="s-total">0</div><div class="stat-label">Total</div></div>
      <div class="stat"><div class="stat-num" id="s-done" style="color:var(--green)">0</div><div class="stat-label">Done</div></div>
      <div class="stat"><div class="stat-num" id="s-pending" style="color:var(--yellow)">0</div><div class="stat-label">Pending</div></div>
      <div class="stat"><div class="stat-num" id="s-overdue" style="color:var(--red)">0</div><div class="stat-label">Overdue</div></div>
    </div>
    <div class="panel">
      <div class="panel-title">My Tasks</div>
      <div class="filters">
        <button class="filter-btn active" onclick="setFilter('all',this)">All</button>
        <button class="filter-btn" onclick="setFilter('pending',this)">Pending</button>
        <button class="filter-btn" onclick="setFilter('done',this)">Done</button>
        <button class="filter-btn" onclick="setFilter('high',this)">High Priority</button>
        <button class="filter-btn" onclick="setFilter('overdue',this)">Overdue</button>
      </div>
      <div class="task-list" id="task-list"></div>
    </div>
  </main>
</div>

<!-- TASK MODAL -->
<div class="overlay" id="modal">
  <div class="modal">
    <div class="modal-title" id="modal-title">New Task</div>
    <div class="field"><label>Title *</label><input type="text" id="t-title" placeholder="What needs to be done?"></div>
    <div class="field"><label>Description</label><textarea id="t-desc" placeholder="Details (optional)"></textarea></div>
    <div class="form-row">
      <div class="field"><label>Priority</label>
        <select id="t-priority"><option value="medium">Medium</option><option value="high">High</option><option value="low">Low</option></select>
      </div>
      <div class="field"><label>Due Date</label><input type="date" id="t-due"></div>
    </div>
    <div class="field"><label>Tag</label><input type="text" id="t-tag" placeholder="e.g. work, personal"></div>
    <div class="modal-actions">
      <button class="btn" onclick="saveTask()" style="flex:1" id="save-btn">Save Task</button>
      <button class="btn btn-ghost" onclick="closeModal()" style="flex:1">Cancel</button>
    </div>
  </div>
</div>

<script>
// ── State ──────────────────────────────────────────────────────────────────
let users = JSON.parse(localStorage.getItem('tf_users')||'[{"id":"u1","name":"Demo User","email":"demo@test.com","password":"password"}]');
let tasks = JSON.parse(localStorage.getItem('tf_tasks')||'[]');
let currentUser = JSON.parse(sessionStorage.getItem('tf_user')||'null');
let filter = 'all', editId = null;

function save(){localStorage.setItem('tf_users',JSON.stringify(users));localStorage.setItem('tf_tasks',JSON.stringify(tasks))}

// ── Auth ───────────────────────────────────────────────────────────────────
function switchTab(t){
  document.getElementById('login-form').style.display=t==='login'?'':'none';
  document.getElementById('register-form').style.display=t==='register'?'':'none';
  document.querySelectorAll('.tab').forEach((b,i)=>b.classList.toggle('active',(t==='login'&&i===0)||(t==='register'&&i===1)));
}
function login(){
  const e=document.getElementById('l-email').value.trim(),p=document.getElementById('l-pass').value;
  const u=users.find(x=>x.email===e&&x.password===p);
  if(!u){document.getElementById('auth-err').textContent='Invalid email or password';return;}
  sessionStorage.setItem('tf_user',JSON.stringify(u));currentUser=u;showApp();
}
function register(){
  const n=document.getElementById('r-name').value.trim(),e=document.getElementById('r-email').value.trim(),p=document.getElementById('r-pass').value;
  if(!n||!e||!p){document.getElementById('reg-err').textContent='All fields required';return;}
  if(users.find(x=>x.email===e)){document.getElementById('reg-err').textContent='Email already registered';return;}
  const u={id:'u'+Date.now(),name:n,email:e,password:p};users.push(u);save();
  sessionStorage.setItem('tf_user',JSON.stringify(u));currentUser=u;showApp();
}
function logout(){sessionStorage.removeItem('tf_user');currentUser=null;document.getElementById('app').style.display='none';document.getElementById('auth').style.display='flex';}
function showApp(){document.getElementById('auth').style.display='none';document.getElementById('app').style.display='flex';document.getElementById('user-name').textContent=currentUser.name;render();}

// ── Tasks ──────────────────────────────────────────────────────────────────
function myTasks(){return tasks.filter(t=>t.userId===currentUser.id)}
function isOverdue(t){return !t.done&&t.due&&new Date(t.due)<new Date(new Date().toDateString())}
function openModal(id=null){
  editId=id;
  const t=id?tasks.find(x=>x.id===id):null;
  document.getElementById('modal-title').textContent=id?'Edit Task':'New Task';
  document.getElementById('t-title').value=t?t.title:'';
  document.getElementById('t-desc').value=t?t.desc:'';
  document.getElementById('t-priority').value=t?t.priority:'medium';
  document.getElementById('t-due').value=t?t.due:'';
  document.getElementById('t-tag').value=t?t.tag:'';
  document.getElementById('modal').classList.add('open');
}
function closeModal(){document.getElementById('modal').classList.remove('open');editId=null;}
function saveTask(){
  const title=document.getElementById('t-title').value.trim();
  if(!title){document.getElementById('t-title').style.borderColor='var(--red)';return;}
  document.getElementById('t-title').style.borderColor='';
  const data={title,desc:document.getElementById('t-desc').value.trim(),priority:document.getElementById('t-priority').value,due:document.getElementById('t-due').value,tag:document.getElementById('t-tag').value.trim()};
  if(editId){Object.assign(tasks.find(t=>t.id===editId),data);}
  else{tasks.push({id:'t'+Date.now(),userId:currentUser.id,...data,done:false,created:Date.now()});}
  save();closeModal();render();
}
function toggleDone(id){const t=tasks.find(x=>x.id===id);t.done=!t.done;save();render();}
function deleteTask(id){if(confirm('Delete this task?')){tasks=tasks.filter(x=>x.id!==id);save();render();}}
function setFilter(f,btn){filter=f;document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');render();}

function render(){
  const all=myTasks();
  const today=new Date(new Date().toDateString());
  document.getElementById('s-total').textContent=all.length;
  document.getElementById('s-done').textContent=all.filter(t=>t.done).length;
  document.getElementById('s-pending').textContent=all.filter(t=>!t.done).length;
  document.getElementById('s-overdue').textContent=all.filter(isOverdue).length;
  let list=all;
  if(filter==='done')list=all.filter(t=>t.done);
  else if(filter==='pending')list=all.filter(t=>!t.done);
  else if(filter==='high')list=all.filter(t=>t.priority==='high'&&!t.done);
  else if(filter==='overdue')list=all.filter(isOverdue);
  list.sort((a,b)=>b.created-a.created);
  const el=document.getElementById('task-list');
  if(!list.length){el.innerHTML=`<div class="empty"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><p>No tasks here</p></div>`;return;}
  el.innerHTML=list.map(t=>{
    const ov=isOverdue(t);
    const dueStr=t.due?`<span class="due${ov?' overdue':''}">📅 ${t.due}</span>`:'';
    const tagStr=t.tag?`<span class="tag">${t.tag}</span>`:'';
    return`<div class="task${t.done?' done':''}">
      <div class="check${t.done?' done':''}" onclick="toggleDone('${t.id}')"><svg width="12" height="12" viewBox="0 0 12 12" fill="white"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
      <div class="task-body">
        <div class="task-title">${t.title}</div>
        ${t.desc?`<div class="task-desc">${t.desc}</div>`:''}
        <div class="task-meta"><span class="badge p-${t.priority}">${t.priority}</span>${tagStr}${dueStr}</div>
      </div>
      <div class="task-actions">
        <button class="icon-btn" onclick="openModal('${t.id}')" title="Edit"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></button>
        <button class="icon-btn" onclick="deleteTask('${t.id}')" title="Delete"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button>
      </div>
    </div>`}).join('');
}

// ── Init ───────────────────────────────────────────────────────────────────
document.getElementById('modal').addEventListener('click',e=>{if(e.target===document.getElementById('modal'))closeModal();});
if(currentUser)showApp();
</script>
</body>
</html>
